<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.plr.frontend.controller.AudioPanelController"
      styleClass="audio-panel"
      prefWidth="220" minWidth="220" maxWidth="220"
      fillWidth="true">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="8">
        <VBox.margin><Insets bottom="10"/></VBox.margin>
        <Label text="&#127911;" styleClass="audio-header-icon"/>
        <Label text="Audio" styleClass="audio-header"/>
    </HBox>

    <!-- Toggle Buttons: Noise | Playlist -->
    <HBox styleClass="audio-tab-bar" spacing="4">
        <Button fx:id="noiseTabBtn"
                text="Noise"
                styleClass="audio-tab-btn, active"
                onAction="#showNoiseTab"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        <Button fx:id="playlistTabBtn"
                text="Playlist"
                styleClass="audio-tab-btn"
                onAction="#showPlaylistTab"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Noise Content -->
    <VBox fx:id="noiseContent" spacing="12" styleClass="audio-tab-content"
          VBox.vgrow="ALWAYS">
        <VBox.margin><Insets top="12" right="0" bottom="0" left="0"/></VBox.margin>

                <Label text="PILIH SUARA AMBIENT"
                       styleClass="audio-section-label"/>

                <!-- 2×2 Grid noise buttons menggunakan nested HBox -->
                <VBox spacing="8">
                    <HBox spacing="8">
                        <!-- White Noise -->
                        <Button fx:id="whiteNoiseBtn"
                                styleClass="noise-btn"
                                onAction="#playWhiteNoise"
                                prefWidth="90" prefHeight="72">
                            <graphic>
                                <VBox alignment="CENTER" spacing="4">
                                    <Label text="&#128267;"
                                           styleClass="noise-icon-label"/>
                                    <Label text="White"
                                           styleClass="noise-title-label"/>
                                    <Label text="Noise"
                                           styleClass="noise-sub-label"/>
                                </VBox>
                            </graphic>
                        </Button>

                        <!-- Brown Noise -->
                        <Button fx:id="brownNoiseBtn"
                                styleClass="noise-btn"
                                onAction="#playBrownNoise"
                                prefWidth="90" prefHeight="72">
                            <graphic>
                                <VBox alignment="CENTER" spacing="4">
                                    <Label text="&#9749;"
                                            styleClass="noise-icon-label"/>
                                    <Label text="Brown"
                                           styleClass="noise-title-label"/>
                                    <Label text="Noise"
                                           styleClass="noise-sub-label"/>
                                </VBox>
                            </graphic>
                        </Button>
                    </HBox>

                    <HBox spacing="8">
                        <!-- Rain -->
                        <Button fx:id="rainNoiseBtn"
                                styleClass="noise-btn"
                                onAction="#playRainNoise"
                                prefWidth="90" prefHeight="72">
                            <graphic>
                                <VBox alignment="CENTER" spacing="4">
                                    <Label text="&#127783;"
                                           styleClass="noise-icon-label"/>
                                    <Label text="Rain"
                                           styleClass="noise-title-label"/>
                                    <Label text="Hujan"
                                           styleClass="noise-sub-label"/>
                                </VBox>
                            </graphic>
                        </Button>

                        <!-- Forest -->
                        <Button fx:id="forestNoiseBtn"
                                styleClass="noise-btn"
                                onAction="#playForestNoise"
                                prefWidth="90" prefHeight="72">
                            <graphic>
                                <VBox alignment="CENTER" spacing="4">
                                    <Label text="&#127807;"
                                           styleClass="noise-icon-label"/>
                                    <Label text="Forest"
                                           styleClass="noise-title-label"/>
                                    <Label text="Hutan"
                                           styleClass="noise-sub-label"/>
                                </VBox>
                            </graphic>
                        </Button>
                    </HBox>
                </VBox>
    </VBox>

    <!-- Playlist Content -->
    <VBox fx:id="playlistContent" spacing="10" styleClass="audio-tab-content"
          VBox.vgrow="ALWAYS" managed="false" visible="false">
        <VBox.margin><Insets top="12" right="0" bottom="0" left="0"/></VBox.margin>

        <Button fx:id="createPlaylistBtn"
                text="+ Buat Playlist"
                styleClass="import-music-btn"
                onAction="#handleCreatePlaylist"
                maxWidth="Infinity"/>

        <HBox fx:id="backNavBar" spacing="8"
              managed="false" visible="false">
            <Button text="&#x2190; Kembali"
                    styleClass="audio-back-btn"
                    onAction="#handleBackToPlaylists"/>
            <Label fx:id="trackListTitle"
                   styleClass="audio-track-title"/>
        </HBox>

        <HBox fx:id="playButtons" spacing="6"
              managed="false" visible="false">
            <Button text="&#x25B6; Putar"
                    styleClass="audio-play-all-btn"
                    onAction="#handleSequentialPlay"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button text="&#x1F500; Acak"
                    styleClass="audio-shuffle-btn"
                    onAction="#handleShufflePlay"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        </HBox>

        <Button fx:id="addTracksBtn"
                text="+ Tambah Lagu"
                styleClass="audio-add-track-btn"
                onAction="#handleAddTracks"
                maxWidth="Infinity"/>

        <Label fx:id="playlistHeader"
               text="DAFTAR PLAYLIST"
               styleClass="audio-section-title"/>

        <StackPane VBox.vgrow="ALWAYS" minHeight="120">
            <ListView fx:id="playlistView"
                      styleClass="playlist-list-view"
                      VBox.vgrow="ALWAYS"/>
            <ListView fx:id="trackView"
                      styleClass="playlist-list-view"
                      VBox.vgrow="ALWAYS"
                      managed="false" visible="false"/>
            <VBox fx:id="emptyPlaylistLabel"
                  alignment="CENTER" spacing="6"
                  style="-fx-opacity:0.5;">
                <Label text="&#x1F3B5;"
                       styleClass="empty-playlist-icon"/>
                <Label text="Belum ada playlist"
                       styleClass="empty-playlist-title"/>
                <Label text="Klik + Buat Playlist untuk memulai"
                       wrapText="true"
                       styleClass="empty-playlist-hint"
                       prefWidth="160"/>
            </VBox>
            <VBox fx:id="createForm" spacing="10"
                  managed="false" visible="false"
                  VBox.vgrow="ALWAYS">
                <Label text="BUAT PLAYLIST BARU"
                       styleClass="audio-form-label"/>
                <TextField fx:id="formNameField"
                           promptText="Nama playlist"
                           styleClass="audio-form-field"/>
                <TextArea fx:id="formDescField"
                          promptText="Deskripsi (opsional)"
                          wrapText="true"
                          prefHeight="50"
                          styleClass="audio-form-textarea"/>
                <Button text="+ Pilih File Audio"
                        styleClass="audio-file-pick-btn"
                        onAction="#handlePickFormFiles"
                        maxWidth="Infinity"/>
                <ListView fx:id="formFileList"
                          styleClass="playlist-list-view"
                          prefHeight="80"
                          style="-fx-background-color:transparent;"/>
                <HBox spacing="6">
                    <Button text="Simpan"
                            styleClass="audio-save-btn"
                            onAction="#handleSavePlaylist"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="Batal"
                            styleClass="audio-cancel-btn"
                            onAction="#handleCancelCreate"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
            </VBox>
        </StackPane>
    </VBox>

    <!-- Shared Volume -->
    <VBox spacing="6" styleClass="audio-tab-content">
        <VBox.margin><Insets top="0" right="0" bottom="0" left="0"/></VBox.margin>
        <Region prefHeight="1" styleClass="audio-divider"/>
        <Label text="VOLUME"
               styleClass="audio-volume-section-label"/>
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label text="&#x1F508;"
                   styleClass="speaker-label"/>
            <Slider fx:id="volumeSlider"
                    min="0" max="1" value="0.7"
                    styleClass="audio-volume-slider"
                    HBox.hgrow="ALWAYS"/>
            <Label fx:id="volumeLabel"
                   text="70%"
                   styleClass="volume-label"
                   prefWidth="32"/>
        </HBox>
    </VBox>

    <!-- Spacer -->
    <Region VBox.vgrow="ALWAYS"/>

    <!-- Player Bar -->
    <VBox styleClass="audio-player-bar" spacing="8">

        <HBox alignment="CENTER_LEFT" spacing="6">
            <Label fx:id="playStateIcon"
                   text="&#x25B6;"
                   styleClass="now-playing-icon"/>
            <Label fx:id="nowPlayingLabel"
                   text="Tidak ada audio"
                   styleClass="now-playing-label"
                   HBox.hgrow="ALWAYS"/>
        </HBox>

        <VBox spacing="4">
            <ProgressBar fx:id="audioProgressBar"
                         progress="0"
                         styleClass="audio-progress-bar"
                         maxWidth="Infinity"/>
            <HBox>
                <Label fx:id="currentTimeLabel"
                       text="0:00"
                       styleClass="time-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="totalDurationLabel"
                       text="0:00"
                       styleClass="time-label"/>
            </HBox>
        </VBox>

        <HBox alignment="CENTER" spacing="2">
            <Button fx:id="prevBtn"
                    text="&#x23EE;"
                    styleClass="audio-ctrl-btn"
                    onAction="#handlePrevious"/>
            <Button fx:id="stopBtn"
                    text="&#x23F9;"
                    styleClass="audio-ctrl-btn"
                    onAction="#handleStop"/>
            <Button fx:id="playPauseBtn"
                    text="&#x25B6;"
                    styleClass="audio-play-btn"
                    onAction="#handlePlayPause"
                    disable="true"/>
            <Button fx:id="nextBtn"
                    text="&#x23ED;"
                    styleClass="audio-ctrl-btn"
                    onAction="#handleNext"/>
            <Button fx:id="loopBtn"
                    text="LP"
                    styleClass="audio-toggle-btn"
                    onAction="#handleToggleLoop">
                <tooltip><Tooltip text="Loop: None \u2192 All \u2192 One \u2192 None"/></tooltip>
            </Button>
            <Button fx:id="shuffleBtn"
                    text="SH"
                    styleClass="audio-toggle-btn"
                    onAction="#handleToggleShuffle">
                <tooltip><Tooltip text="Acak: nyala/mati"/></tooltip>
            </Button>
        </HBox>

    </VBox>

</VBox>
