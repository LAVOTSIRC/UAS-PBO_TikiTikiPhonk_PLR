<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    AudioPanel.fxml — Panel Audio Companion (220px, kanan)
    Struktur:
      ┌─ Header ───────────────────────────────────┐
      ├─ TabPane: [Noise] [Playlist] ──────────────┤
      │   Noise Tab:                               │
      │     2×2 grid tombol noise bawaan           │
      │     Slider volume                          │
      │   Playlist Tab:                            │
      │     Tombol Import Music                    │
      │     ListView daftar lagu                   │
      │     Slider volume                          │
      ├─ [spacer] ──────────────────────────────── │
      └─ Player Bar (selalu terlihat di bawah) ────┘
           Now Playing label
           ProgressBar + waktu
           Kontrol: ⏮  ⏹  ▶/⏸  ⏭
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.plr.frontend.controller.AudioPanelController"
      styleClass="audio-panel"
      prefWidth="220" minWidth="220" maxWidth="220"
      fillWidth="true">

    <!-- ===== Header ===== -->
    <HBox alignment="CENTER_LEFT" spacing="8">
        <VBox.margin><Insets bottom="10"/></VBox.margin>
        <Label text="&#127911;" style="-fx-font-size:14px; -fx-text-fill:#C084FC;"/>
        <Label text="Audio" styleClass="audio-header"/>
    </HBox>

    <!-- ===== TabPane: Noise | Playlist ===== -->
    <TabPane fx:id="audioTabPane"
             styleClass="audio-tab-pane"
             tabClosingPolicy="UNAVAILABLE"
             VBox.vgrow="ALWAYS">

        <!-- ─── TAB: NOISE ─────────────────────────────── -->
        <Tab text="Noise">
            <VBox spacing="12" styleClass="audio-tab-content">
                <padding><Insets top="12" right="0" bottom="8" left="0"/></padding>

                <Label text="PILIH SUARA AMBIENT"
                       style="-fx-font-size:9px; -fx-text-fill:#7C6E8A; -fx-font-weight:bold;"/>

                <!-- 2×2 Grid noise buttons menggunakan nested HBox -->
                <VBox spacing="8">
                    <HBox spacing="8">
                        <!-- White Noise -->
                        <Button fx:id="whiteNoiseBtn"
                                styleClass="noise-btn"
                                onAction="#playWhiteNoise"
                                prefWidth="90" prefHeight="72">
                            <graphic>
                                <VBox alignment="CENTER" spacing="4">
                                    <Label text="&#128267;"
                                           style="-fx-font-size:22px; -fx-text-fill:#F0EAFF;"/>
                                    <Label text="White"
                                           style="-fx-font-size:10px; -fx-text-fill:#F0EAFF; -fx-font-weight:bold;"/>
                                    <Label text="Noise"
                                           style="-fx-font-size:9px; -fx-text-fill:#7C6E8A;"/>
                                </VBox>
                            </graphic>
                        </Button>

                        <!-- Brown Noise -->
                        <Button fx:id="brownNoiseBtn"
                                styleClass="noise-btn"
                                onAction="#playBrownNoise"
                                prefWidth="90" prefHeight="72">
                            <graphic>
                                <VBox alignment="CENTER" spacing="4">
                                    <Label text="&#9749;"
                                           style="-fx-font-size:22px; -fx-text-fill:#F0EAFF;"/>
                                    <Label text="Brown"
                                           style="-fx-font-size:10px; -fx-text-fill:#F0EAFF; -fx-font-weight:bold;"/>
                                    <Label text="Noise"
                                           style="-fx-font-size:9px; -fx-text-fill:#7C6E8A;"/>
                                </VBox>
                            </graphic>
                        </Button>
                    </HBox>

                    <HBox spacing="8">
                        <!-- Rain -->
                        <Button fx:id="rainNoiseBtn"
                                styleClass="noise-btn"
                                onAction="#playRainNoise"
                                prefWidth="90" prefHeight="72">
                            <graphic>
                                <VBox alignment="CENTER" spacing="4">
                                    <Label text="&#127783;"
                                           style="-fx-font-size:22px; -fx-text-fill:#F0EAFF;"/>
                                    <Label text="Rain"
                                           style="-fx-font-size:10px; -fx-text-fill:#F0EAFF; -fx-font-weight:bold;"/>
                                    <Label text="Hujan"
                                           style="-fx-font-size:9px; -fx-text-fill:#7C6E8A;"/>
                                </VBox>
                            </graphic>
                        </Button>

                        <!-- Forest -->
                        <Button fx:id="forestNoiseBtn"
                                styleClass="noise-btn"
                                onAction="#playForestNoise"
                                prefWidth="90" prefHeight="72">
                            <graphic>
                                <VBox alignment="CENTER" spacing="4">
                                    <Label text="&#127807;"
                                           style="-fx-font-size:22px; -fx-text-fill:#F0EAFF;"/>
                                    <Label text="Forest"
                                           style="-fx-font-size:10px; -fx-text-fill:#F0EAFF; -fx-font-weight:bold;"/>
                                    <Label text="Hutan"
                                           style="-fx-font-size:9px; -fx-text-fill:#7C6E8A;"/>
                                </VBox>
                            </graphic>
                        </Button>
                    </HBox>
                </VBox>

                <!-- Divider -->
                <Region prefHeight="1" styleClass="audio-divider"/>

                <!-- Volume Row -->
                <Label text="VOLUME"
                       style="-fx-font-size:9px; -fx-text-fill:#7C6E8A; -fx-font-weight:bold;"/>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="&#128264;"
                           style="-fx-text-fill:#7C6E8A; -fx-font-size:12px;"/>
                    <Slider fx:id="volumeSlider"
                            min="0" max="1" value="0.7"
                            styleClass="audio-volume-slider"
                            HBox.hgrow="ALWAYS"/>
                    <Label fx:id="volumeLabel"
                           text="70%"
                           styleClass="volume-label"
                           prefWidth="32"/>
                </HBox>

            </VBox>
        </Tab>

        <!-- ─── TAB: PLAYLIST ──────────────────────────── -->
        <Tab text="Playlist">
            <VBox spacing="10">
                <padding><Insets top="12" right="0" bottom="8" left="0"/></padding>

                <!-- Import Button -->
                <Button text="&#43; Import Music"
                        styleClass="import-music-btn"
                        onAction="#handleImportMusic"
                        maxWidth="Infinity"/>

                <Label text="ANTRIAN LAGU"
                       style="-fx-font-size:9px; -fx-text-fill:#7C6E8A; -fx-font-weight:bold;"/>

                <!-- Playlist ListView -->
                <StackPane VBox.vgrow="ALWAYS" minHeight="120">
                    <ListView fx:id="playlistView"
                              styleClass="playlist-list-view"
                              VBox.vgrow="ALWAYS"/>

                    <!-- Placeholder saat playlist kosong -->
                    <VBox fx:id="emptyPlaylistLabel"
                          alignment="CENTER" spacing="6"
                          style="-fx-opacity:0.5;">
                        <Label text="&#127925;"
                               style="-fx-font-size:28px; -fx-text-fill:#7C6E8A;"/>
                        <Label text="Belum ada lagu"
                               style="-fx-font-size:11px; -fx-text-fill:#7C6E8A;"/>
                        <Label text="Klik + Import untuk menambahkan"
                               wrapText="true"
                               style="-fx-font-size:9px; -fx-text-fill:#7C6E8A; -fx-text-alignment:center;"
                               prefWidth="160"/>
                    </VBox>
                </StackPane>

            </VBox>
        </Tab>

    </TabPane>

    <!-- Spacer -->
    <Region VBox.vgrow="ALWAYS"/>

    <!-- ===== PLAYER BAR (selalu terlihat di bawah) ===== -->
    <VBox styleClass="audio-player-bar" spacing="8">

        <!-- Now Playing Info -->
        <HBox alignment="CENTER_LEFT" spacing="6">
            <Label text="&#9654;"
                   style="-fx-text-fill:#C084FC; -fx-font-size:9px;"/>
            <Label fx:id="nowPlayingLabel"
                   text="Tidak ada audio"
                   styleClass="now-playing-label"
                   HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Progress Bar + Time Labels -->
        <VBox spacing="4">
            <ProgressBar fx:id="audioProgressBar"
                         progress="0"
                         styleClass="audio-progress-bar"
                         maxWidth="Infinity"/>
            <HBox>
                <Label fx:id="currentTimeLabel"
                       text="0:00"
                       styleClass="time-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="totalDurationLabel"
                       text="0:00"
                       styleClass="time-label"/>
            </HBox>
        </VBox>

        <!-- Controls Row: ⏮  ⏹  ▶/⏸  ⏭ -->
        <HBox alignment="CENTER" spacing="6">

            <Button fx:id="prevBtn"
                    text="⏮"
                    styleClass="audio-ctrl-btn"
                    onAction="#handlePrevious"/>

            <Button fx:id="stopBtn"
                    text="⏹"
                    styleClass="audio-ctrl-btn"
                    onAction="#handleStop"/>

            <Button fx:id="playPauseBtn"
                    text="▶"
                    styleClass="audio-play-btn"
                    onAction="#handlePlayPause"
                    disable="true"/>

            <Button fx:id="nextBtn"
                    text="⏭"
                    styleClass="audio-ctrl-btn"
                    onAction="#handleNext"/>

        </HBox>

    </VBox>

</VBox>
