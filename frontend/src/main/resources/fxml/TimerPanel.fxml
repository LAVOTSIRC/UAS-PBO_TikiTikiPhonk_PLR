<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Arc?>
<?import javafx.scene.shape.Circle?>

<!--
    TimerPanel.fxml — Area Timer Pomodoro Tengah (mengisi sisa ruang)
    Berisi: tab Fokus/Istirahat, lingkaran progress, angka timer, kontrol
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.plr.frontend.controller.TimerPanelController"
      styleClass="timer-panel"
      alignment="CENTER"
      HBox.hgrow="ALWAYS"
      fillWidth="true">

    <!-- ===== Tab Bar: Fokus | Istirahat ===== -->
    <HBox styleClass="timer-tab-bar"
          alignment="CENTER"
          spacing="2">
        <VBox.margin><Insets bottom="24"/></VBox.margin>

        <Button fx:id="focusTabBtn"
                text="Fokus"
                styleClass="timer-tab-btn, active"
                onAction="#handleFocusTab"/>

        <Button fx:id="breakTabBtn"
                text="Istirahat"
                styleClass="timer-tab-btn"
                onAction="#handleBreakTab"/>
    </HBox>

    <!-- ===== Circular Timer Progress Ring ===== -->
    <!--
        StackPane 270x270.
        Circle (background ring) dan Arc (progress) sama-sama berpusat di (0,0).
        StackPane otomatis center-kan kedua shape karena bounding box mereka
        identik dan simetris terhadap origin.
    -->
    <StackPane prefWidth="270" prefHeight="270"
               alignment="CENTER"
               styleClass="timer-circle-container">
        <VBox.margin><Insets bottom="24"/></VBox.margin>

        <!-- Background ring (static) -->
        <Circle radius="120"
                fill="transparent"
                stroke="#2D2936"
                strokeWidth="10"/>

        <!-- Progress arc (dinamis - dikendalikan controller) -->
        <Arc fx:id="timerArc"
             radiusX="120" radiusY="120"
             startAngle="90" length="360"
             type="OPEN"
             fill="transparent"
             stroke="#C084FC"
             strokeWidth="10"
             strokeLineCap="ROUND"/>

        <!-- Center text overlay -->
        <VBox alignment="CENTER" spacing="6">
            <Label fx:id="timerLabel"
                   text="25:00"
                   styleClass="timer-display"
                   alignment="CENTER"/>
            <Label fx:id="sessionTypeLabel"
                   text="Sesi Fokus"
                   styleClass="timer-session-type"
                   alignment="CENTER"/>
        </VBox>

    </StackPane>

    <!-- ===== Session Info ===== -->
    <Label fx:id="sessionCountLabel"
           text=""
           styleClass="timer-session-count"
           alignment="CENTER">
        <VBox.margin><Insets bottom="8"/></VBox.margin>
    </Label>

    <!-- ===== Playback Controls ===== -->
    <HBox styleClass="timer-controls"
          alignment="CENTER"
          spacing="16">
        <VBox.margin><Insets bottom="12"/></VBox.margin>

        <!-- Skip Button (left) -->
        <Button fx:id="skipBtn"
                text="⏭"
                styleClass="timer-control-btn"
                onAction="#handleSkip"/>

        <!-- Play / Pause Button (center, larger) -->
        <Button fx:id="playPauseBtn"
                text="▶"
                styleClass="timer-play-btn"
                onAction="#handlePlayPause"/>

        <!-- Placeholder right side (symmetry) -->
        <Region prefWidth="48"/>

    </HBox>

    <!-- ===== Status Label ===== -->
    <Label fx:id="statusLabel"
           text=""
           styleClass="timer-status"
           alignment="CENTER"/>

</VBox>
