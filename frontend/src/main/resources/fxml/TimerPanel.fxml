<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Arc?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.plr.frontend.controller.TimerPanelController"
      styleClass="timer-panel"
      alignment="CENTER"
      HBox.hgrow="ALWAYS"
      fillWidth="true">

    <Label fx:id="cycleLabel"
           text="Sesi Fokus ke-1"
           styleClass="timer-cycle-label"
           alignment="CENTER">
        <VBox.margin><Insets bottom="8"/></VBox.margin>
    </Label>

    <Label fx:id="activeTaskLabel"
           text=""
           styleClass="timer-active-task"
           visible="false"
           alignment="CENTER"/>

    <StackPane prefWidth="270" prefHeight="270"
               alignment="CENTER"
               styleClass="timer-circle-container">
        <VBox.margin><Insets bottom="16"/></VBox.margin>

        <Circle radius="120"
                fill="transparent"
                styleClass="timer-bg-ring"
                strokeWidth="10"/>

        <Arc fx:id="timerArc"
             radiusX="120" radiusY="120"
             startAngle="90" length="360"
             type="OPEN"
             fill="transparent"
             styleClass="timer-progress-ring"
             strokeWidth="10"
             strokeLineCap="ROUND"/>

        <VBox alignment="CENTER" spacing="6">
            <Label fx:id="timerLabel"
                   text="25:00"
                   styleClass="timer-display"
                   alignment="CENTER"/>
            <Label fx:id="sessionTypeLabel"
                   text="Sesi Fokus"
                   styleClass="timer-session-type"
                   alignment="CENTER"/>
        </VBox>

    </StackPane>

    <HBox fx:id="sessionDots"
          styleClass="session-dots"
          alignment="CENTER"
          spacing="6">
        <VBox.margin><Insets bottom="8"/></VBox.margin>
    </HBox>

    <Label fx:id="pointsLabel"
           text=""
           styleClass="timer-points"
           alignment="CENTER"/>

    <Label fx:id="sessionCountLabel"
           text=""
           styleClass="timer-session-count"
           alignment="CENTER">
        <VBox.margin><Insets bottom="8"/></VBox.margin>
    </Label>

    <HBox styleClass="timer-controls"
          alignment="CENTER"
          spacing="16">
        <VBox.margin><Insets bottom="12"/></VBox.margin>

        <Button fx:id="skipBtn"
                text="⏭"
                styleClass="timer-control-btn"
                onAction="#handleSkip"/>

        <Button fx:id="playPauseBtn"
                text="▶"
                styleClass="timer-play-btn"
                onAction="#handlePlayPause"/>

        <Region prefWidth="48"/>
    </HBox>

    <Label fx:id="statusLabel"
           text=""
           styleClass="timer-status"
           alignment="CENTER"/>

</VBox>
