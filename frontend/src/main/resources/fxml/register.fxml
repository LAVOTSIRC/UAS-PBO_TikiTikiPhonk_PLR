<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.plr.frontend.controller.RegisterController"
           styleClass="auth-root"
           prefWidth="480" prefHeight="620">

    <VBox styleClass="auth-card"
          alignment="CENTER"
          spacing="0"
          maxWidth="400" maxHeight="580"
          StackPane.alignment="CENTER">

        <!-- Logo -->
        <ImageView styleClass="auth-logo" fitWidth="140" preserveRatio="true">
            <Image url="@../images/TikiTikiPhonk%20Logo.png"/>
        </ImageView>

        <!-- Title -->
        <Label text="Buat Akun Baru" styleClass="auth-title">
            <VBox.margin><Insets top="8" bottom="4"/></VBox.margin>
        </Label>

        <Label text="Bergabunglah dan mulai sesi fokus mu." styleClass="auth-subtitle">
            <VBox.margin><Insets bottom="24"/></VBox.margin>
        </Label>

        <!-- Username -->
        <Label text="USERNAME" styleClass="auth-field-label"/>
        <TextField fx:id="usernameField"
                   promptText="Minimal 3 karakter"
                   styleClass="text-field, auth-input">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </TextField>

        <!-- Email -->
        <Label text="EMAIL" styleClass="auth-field-label"/>
        <TextField fx:id="emailField"
                   promptText="email@contoh.com"
                   styleClass="text-field, auth-input">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </TextField>

        <!-- Password -->
        <Label text="PASSWORD" styleClass="auth-field-label"/>
        <PasswordField fx:id="passwordField"
                       promptText="Minimal 6 karakter"
                       styleClass="password-field, auth-input">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </PasswordField>

        <!-- Confirm Password -->
        <Label text="KONFIRMASI PASSWORD" styleClass="auth-field-label"/>
        <PasswordField fx:id="confirmPasswordField"
                       promptText="Ulangi password kamu"
                       styleClass="password-field, auth-input">
            <VBox.margin><Insets bottom="16"/></VBox.margin>
        </PasswordField>

        <!-- Error Label -->
        <Label fx:id="errorLabel"
               text=""
               styleClass="error-label"
               visible="false"
               wrapText="true">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </Label>

        <!-- Register Button -->
        <Button fx:id="registerButton"
                text="Daftar"
                styleClass="button, button-primary, auth-btn"
                onAction="#handleRegister"
                defaultButton="true">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </Button>

        <!-- Loading Indicator -->
        <ProgressIndicator fx:id="loadingIndicator"
                           visible="false"
                           styleClass="progress-indicator">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </ProgressIndicator>

        <!-- Login Link -->
        <HBox alignment="CENTER" spacing="6">
            <Label text="Sudah punya akun?" styleClass="auth-subtitle"/>
            <Button text="Masuk di sini"
                    styleClass="link-button"
                    onAction="#goToLogin"/>
        </HBox>

    </VBox>

</StackPane>
