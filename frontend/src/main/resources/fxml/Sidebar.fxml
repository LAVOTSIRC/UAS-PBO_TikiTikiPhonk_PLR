<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    Sidebar.fxml — Panel Navigasi Kiri (56px)
    PERBAIKAN: semua tombol menggunakan <graphic><Label> seperti pola audio buttons
    agar ikon Unicode/emoji tampil di JavaFX Windows (Button text tidak render emoji,
    tapi Label graphic bisa)
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.plr.frontend.controller.SidebarController"
      styleClass="sidebar"
      prefWidth="56" minWidth="56" maxWidth="56"
      fillWidth="true">

    <!-- User Avatar (initial) -->
    <Label fx:id="usernameInitialLabel"
           text="U"
           styleClass="sidebar-avatar"
            alignment="CENTER"
            onMouseClicked="#handleProfileNav">
        <VBox.margin><Insets top="8" bottom="16"/></VBox.margin>
        <tooltip><Tooltip text="Profil kamu"/></tooltip>
    </Label>

    <!-- Nav: Tasks — menggunakan graphic label (bukan button text) -->
    <Button fx:id="tasksNavBtn"
            styleClass="sidebar-nav-btn, active"
            onAction="#handleTasksNav">
        <graphic>
            <Label text="✅"
                   style="-fx-font-size:20px; -fx-background-color:transparent; -fx-padding:0;"/>
        </graphic>
        <VBox.margin><Insets bottom="4"/></VBox.margin>
        <tooltip><Tooltip text="To-Do List"/></tooltip>
    </Button>


    <!-- Theme Toggle -->
    <Button fx:id="themeToggleBtn"
            styleClass="sidebar-nav-btn"
            onAction="#handleThemeToggle">
        <graphic>
            <Label fx:id="themeIconLabel"
                   text="☾"
                   style="-fx-font-size:18px; -fx-background-color:transparent; -fx-padding:0;"/>
        </graphic>
        <tooltip><Tooltip text="Ganti tema"/></tooltip>
    </Button>

    <!-- Spacer -->
    <Region VBox.vgrow="ALWAYS"/>

    <!-- Logout Button — fx:id agar bisa dikontrol dari SidebarController -->
    <Button fx:id="logoutBtn"
            styleClass="sidebar-logout-btn"
            onAction="#handleLogout">
        <graphic>
            <Label text="🚪"
                   style="-fx-font-size:20px; -fx-background-color:transparent; -fx-padding:0;"/>
        </graphic>
        <VBox.margin><Insets bottom="8"/></VBox.margin>
        <tooltip><Tooltip text="Keluar"/></tooltip>
    </Button>

</VBox>
