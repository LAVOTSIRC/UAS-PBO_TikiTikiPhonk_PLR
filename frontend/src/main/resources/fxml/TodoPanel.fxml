<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    TodoPanel.fxml — Panel Daftar Tugas (240px)
    PERBAIKAN:
    - Tombol "+" eksplisit dengan graphic label (bukan button text emoji)
    - Hapus emoji dari tombol delete (ganti dengan teks biasa)
    - Input field dengan border lebih terang agar terlihat
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.plr.frontend.controller.TodoPanelController"
      styleClass="todo-panel"
      prefWidth="240" minWidth="240" maxWidth="240"
      fillWidth="true" VBox.vgrow="ALWAYS">

    <!-- Header Row -->
    <HBox alignment="CENTER_LEFT" spacing="8">
        <Label text="TO-DO" styleClass="panel-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" text="" styleClass="section-label"/>
        <!-- Tombol "+" -->
        <Button styleClass="add-task-btn"
                onAction="#handleAddTask"
                minWidth="24" minHeight="24"
                prefWidth="24" prefHeight="24">
            <graphic>
                <Label text="+"
                       style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#C084FC; -fx-background-color:transparent; -fx-padding:0;"/>
            </graphic>
        </Button>
    </HBox>

    <!-- Input Row: input field tanpa HBox agar tidak collapse -->
    <TextField fx:id="taskInputField"
               promptText="Tambah tugas baru..."
               styleClass="task-input"
               onAction="#handleAddTask">
        <VBox.margin><Insets top="10" bottom="10"/></VBox.margin>
    </TextField>

    <!-- Section: Aktif -->
    <Label text="AKTIF" styleClass="panel-label">
        <VBox.margin><Insets bottom="4"/></VBox.margin>
    </Label>

    <!-- Active Tasks ListView -->
    <ListView fx:id="activeTasksList"
              styleClass="task-list-view"
              VBox.vgrow="ALWAYS"
              prefHeight="180"/>

    <!-- Section: Selesai -->
    <Label text="SELESAI" styleClass="panel-label">
        <VBox.margin><Insets top="6" bottom="4"/></VBox.margin>
    </Label>

    <!-- Completed Tasks ListView -->
    <ListView fx:id="completedTasksList"
              styleClass="task-list-view, completed-list-view"
              VBox.vgrow="SOMETIMES"
              prefHeight="100"/>

    <!-- Delete Button — teks biasa (tanpa emoji) agar selalu terbaca -->
    <Button text="Hapus Tugas Dipilih"
            styleClass="todo-delete-btn"
            onAction="#handleDeleteSelected">
        <VBox.margin><Insets top="8"/></VBox.margin>
    </Button>

    <!-- Spacer -->
    <Region VBox.vgrow="ALWAYS"/>

    <!-- Session Summary Card -->
    <VBox styleClass="session-history">
        <VBox.margin><Insets top="8"/></VBox.margin>
        <Label text="SESI HARI INI" styleClass="panel-label"/>
        
        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox.margin><Insets top="8"/></VBox.margin>
            
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Region styleClass="session-dot, dot-purple"/>
                <Label fx:id="sessionCountLabel" text="0 sesi" styleClass="session-stat"/>
            </HBox>
        </HBox>
    </VBox>

</VBox>
