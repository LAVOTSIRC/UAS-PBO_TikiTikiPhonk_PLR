<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    TodoPanel.fxml — Panel Daftar Tugas (240px)
    PERBAIKAN:
    - Tombol "+" eksplisit dengan graphic label (bukan button text emoji)
    - Hapus emoji dari tombol delete (ganti dengan teks biasa)
    - Input field dengan border lebih terang agar terlihat
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.plr.frontend.controller.TodoPanelController"
      styleClass="todo-panel"
      prefWidth="300" minWidth="300" maxWidth="300"
      fillWidth="true" VBox.vgrow="ALWAYS">

    <!-- Header Row -->
    <HBox alignment="CENTER_LEFT" spacing="8">
        <Label text="TO-DO LIST" styleClass="todo-title-label"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Tombol Tambah Tugas Baru -->
    <Button text="+ Tambah Tugas"
            styleClass="add-task-btn"
            maxWidth="Infinity"
            onAction="#handleOpenTaskModal">
        <VBox.margin><Insets top="15" bottom="10"/></VBox.margin>
    </Button>

    <!-- Search Row -->
    <TextField fx:id="searchField"
               promptText="Cari tugas..."
               styleClass="task-input">
        <VBox.margin><Insets bottom="8"/></VBox.margin>
    </TextField>

    <!-- Filter & Sort Dropdowns -->
    <HBox spacing="8">
        <ComboBox fx:id="filterCategoryComboBox" styleClass="todo-combo-box" maxWidth="Infinity" HBox.hgrow="ALWAYS" promptText="Filter"/>
        <ComboBox fx:id="sortTaskComboBox" styleClass="todo-combo-box" maxWidth="Infinity" HBox.hgrow="ALWAYS" promptText="Urutkan"/>
        <VBox.margin><Insets bottom="10"/></VBox.margin>
    </HBox>

    <!-- Section: Aktif -->
    <Label text="AKTIF" styleClass="panel-label">
        <VBox.margin><Insets bottom="4"/></VBox.margin>
    </Label>

    <!-- Active Tasks ListView -->
    <ListView fx:id="activeTasksList"
              styleClass="task-list-view"
              VBox.vgrow="ALWAYS"
              prefHeight="180"/>

    <!-- Section: Selesai -->
    <Label text="SELESAI" styleClass="panel-label">
        <VBox.margin><Insets top="6" bottom="4"/></VBox.margin>
    </Label>

    <!-- Completed Tasks ListView -->
    <ListView fx:id="completedTasksList"
              styleClass="task-list-view, completed-list-view"
              VBox.vgrow="SOMETIMES"
              prefHeight="100"/>

    <!-- Spacer -->
    <Region VBox.vgrow="ALWAYS"/>

    <!-- Delete Button — teks biasa (tanpa emoji) agar selalu terbaca -->
    <Button text="Hapus Tugas Dipilih"
            styleClass="todo-delete-btn"
            maxWidth="Infinity"
            onAction="#handleDeleteSelected">
        <VBox.margin><Insets top="8" bottom="8"/></VBox.margin>
    </Button>

    <!-- Session Summary Card -->
    <VBox styleClass="session-history">
        <VBox.margin><Insets top="8"/></VBox.margin>
        <Label text="SESI HARI INI" styleClass="panel-label"/>
        
        <VBox spacing="8" alignment="CENTER_LEFT">
            <VBox.margin><Insets top="8"/></VBox.margin>
            
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Region styleClass="session-dot, dot-purple"/>
                <Label fx:id="sessionCountLabel" text="0 sesi" styleClass="session-stat"/>
            </HBox>
            
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="⏱" styleClass="session-stat"/>
                <Label fx:id="focusMinutesLabel" text="0 mnt" styleClass="session-stat"/>
            </HBox>
            
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="✓" styleClass="session-stat"/>
                <Label fx:id="tasksDoneLabel" text="0 tugas" styleClass="session-stat"/>
            </HBox>
        </VBox>
    </VBox>

</VBox>
