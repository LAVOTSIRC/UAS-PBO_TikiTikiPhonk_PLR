<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.plr.frontend.controller.TaskModalController"
      style="-fx-background-color: #1A1722; -fx-padding: 24; -fx-border-color: #3D2E52; -fx-border-width: 1;"
      spacing="16" prefWidth="480">

    <Label fx:id="modalTitleLabel" text="Detail Tugas" style="-fx-text-fill: #F0EAFF; -fx-font-size: 18px; -fx-font-weight: bold;"/>

    <VBox spacing="5">
        <Label text="Judul Tugas" style="-fx-text-fill: #B0A3C6; -fx-font-size: 12px;"/>
        <TextField fx:id="titleField" promptText="Masukkan judul tugas" styleClass="task-input"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Kategori" style="-fx-text-fill: #B0A3C6; -fx-font-size: 12px;"/>
        <ComboBox fx:id="categoryComboBox" maxWidth="Infinity" styleClass="todo-combo-box"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Tenggat Waktu (Tanggal &amp; Jam)" style="-fx-text-fill: #B0A3C6; -fx-font-size: 12px;"/>
        <DatePicker fx:id="dueDatePicker" maxWidth="Infinity" styleClass="task-input"/>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <VBox.margin><Insets top="5"/></VBox.margin>
            <ComboBox fx:id="hourComboBox" prefWidth="100" styleClass="todo-combo-box" promptText="Jam"/>
            <Label text=":" style="-fx-text-fill: #F0EAFF; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            <ComboBox fx:id="minuteComboBox" prefWidth="100" styleClass="todo-combo-box" promptText="Mnt"/>
        </HBox>
    </VBox>

    <VBox spacing="5">
        <Label text="Deskripsi" style="-fx-text-fill: #B0A3C6; -fx-font-size: 12px;"/>
        <TextArea fx:id="descriptionArea" promptText="Tulis deskripsi detail (opsional)" prefRowCount="4" wrapText="true" styleClass="task-input"/>
    </VBox>

    <Label fx:id="errorLabel" text="" style="-fx-text-fill: #FF6B6B; -fx-font-size: 12px;"/>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button fx:id="deleteBtn" text="Hapus Tugas" style="-fx-background-color: #3D2E52; -fx-text-fill: #FF6B6B; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 16; -fx-font-weight: bold;" onAction="#handleDelete" visible="false"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="cancelCompleteBtn" text="Batal Selesai" style="-fx-background-color: #3D2E52; -fx-text-fill: #C084FC; -fx-border-color: #C084FC; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 16;" onAction="#handleCancelComplete" visible="false"/>
        <Button fx:id="cancelBtn" text="Batal" style="-fx-background-color: #2D2936; -fx-text-fill: #F0EAFF; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 20;" onAction="#handleCancel"/>
        <Button fx:id="saveBtn" text="Simpan" style="-fx-background-color: #C084FC; -fx-text-fill: #1A1722; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 20;" onAction="#handleSave"/>
    </HBox>
</VBox>
