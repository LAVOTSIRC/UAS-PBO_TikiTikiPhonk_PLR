<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.plr.frontend.controller.MainLayoutController"
            styleClass="main-layout">

    <!-- Main Content fills entire anchor pane -->
    <HBox AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"
          fillHeight="true">

        <!-- Sidebar -->
        <fx:include fx:id="sidebar" source="Sidebar.fxml"/>

        <!-- Content host -->
        <StackPane HBox.hgrow="ALWAYS">

            <!-- Task View: Todo + Timer + Audio -->
            <HBox fx:id="taskView" fillHeight="true" managed="true" visible="true">
                <fx:include fx:id="todoPanel" source="TodoPanel.fxml"/>
                <fx:include fx:id="timerPanel" source="TimerPanel.fxml"/>
                <fx:include fx:id="audioPanel" source="AudioPanel.fxml"/>
            </HBox>

            <!-- Stats View -->
            <fx:include fx:id="statsPanel" source="StatsPanel.fxml" managed="false" visible="false"/>

            <!-- Profile Panel -->
            <fx:include fx:id="profilePanel" source="ProfilePanel.fxml" visible="false" managed="false"/>

        </StackPane>

    </HBox>

    <!-- Global Notification Overlay — transparent to mouse, bottom center -->
    <StackPane AnchorPane.topAnchor="0"
               AnchorPane.bottomAnchor="0"
               AnchorPane.leftAnchor="0"
               AnchorPane.rightAnchor="0"
               pickOnBounds="false">
        <VBox alignment="BOTTOM_CENTER" maxWidth="400" maxHeight="100">
            <StackPane.margin><Insets bottom="60"/></StackPane.margin>
            <Label fx:id="globalStatusLabel" text="" visible="false"
                   styleClass="global-status-label"
                   style="-fx-padding: 10 20; -fx-background-radius: 20; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 10, 0, 0, 5);"/>
        </VBox>
    </StackPane>

</AnchorPane>
