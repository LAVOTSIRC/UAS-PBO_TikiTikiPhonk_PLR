<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<!--
    MainLayout.fxml — Shell Utama
    Mengatur tata letak 4 panel via fx:include:
      1. Sidebar   (56px  - nav kiri)
      2. TodoPanel (240px - daftar tugas)
      3. TimerPanel(fills - pomodoro timer)
      4. AudioPanel(220px - audio companion)
-->
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.plr.frontend.controller.MainLayoutController"
           styleClass="main-layout"
           prefWidth="1100" prefHeight="700">

    <HBox fillHeight="true">

    <!-- Sidebar: ikon navigasi kiri -->
    <fx:include fx:id="sidebar" source="Sidebar.fxml"/>

    <!-- Content host: dashboard/profile -->
    <StackPane HBox.hgrow="ALWAYS">

    <HBox fx:id="dashboardContent" fillHeight="true" visible="true" managed="true">

    <!-- Todo Panel: daftar tugas -->
    <fx:include fx:id="todoPanel" source="TodoPanel.fxml"/>

    <!-- Timer Panel: Pomodoro (mengisi sisa ruang) -->
    <fx:include fx:id="timerPanel" source="TimerPanel.fxml"/>

    <!-- Audio Panel: noise & playlist -->
    <fx:include fx:id="audioPanel" source="AudioPanel.fxml"/>

    </HBox>

    <!-- Profile Panel -->
    <fx:include fx:id="profilePanel" source="ProfilePanel.fxml" visible="false" managed="false"/>

    </StackPane>

    </HBox>

    <!-- Global Notification Overlay -->
    <VBox alignment="BOTTOM_CENTER" StackPane.alignment="BOTTOM_CENTER" pickOnBounds="false" maxWidth="400" maxHeight="100">
        <StackPane.margin><javafx.geometry.Insets bottom="60"/></StackPane.margin>
        <Label fx:id="globalStatusLabel" text="" visible="false"
               styleClass="global-status-label"
               style="-fx-padding: 10 20; -fx-background-radius: 20; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 10, 0, 0, 5);"/>
    </VBox>
</StackPane>
