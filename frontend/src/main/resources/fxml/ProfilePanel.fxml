<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.plr.frontend.controller.ProfilePanelController"
      styleClass="profile-panel"
      fillWidth="true"
      spacing="0">

    <!-- ========== HEADER CARD ========== -->
    <VBox styleClass="profile-header-card" spacing="0">
        <VBox.margin><Insets top="24" right="28" bottom="0" left="28"/></VBox.margin>

        <!-- User Avatar & Basic Info -->
        <HBox alignment="CENTER_LEFT" spacing="20">

            <!-- Avatar Stack: Circle + Initial Letter -->
            <StackPane prefWidth="80" prefHeight="80">
                <Circle fx:id="userAvatarCircle"
                        radius="40"
                        styleClass="profile-avatar-bg"
                        fill="#C084FC"/>
                <Label fx:id="avatarInitialLabel"
                       text="U"
                       styleClass="profile-avatar-initial"/>
            </StackPane>

            <!-- User Info -->
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="usernameLabel"
                       text="username"
                       styleClass="profile-username"/>
                <Label fx:id="emailLabel"
                       text="user@example.com"
                       styleClass="profile-email"/>
                <Label fx:id="joinedDateLabel"
                       text="Bergabung 14 Juni 2026"
                       styleClass="profile-joined-date"/>
            </VBox>

            <!-- Edit Profile Button -->
            <Button fx:id="editProfileBtn"
                    text="Edit Profil"
                    styleClass="button, button-primary"
                    onAction="#handleEditProfile"
                    prefWidth="120"/>
        </HBox>

        <!-- Quick Stats Row under header -->
        <HBox styleClass="profile-quick-stats" spacing="12">
            <VBox.margin><Insets top="20" bottom="0"/></VBox.margin>

            <VBox styleClass="quick-stat-item" HBox.hgrow="ALWAYS">
                <Label fx:id="totalSessionsLabel" text="0" styleClass="quick-stat-value"/>
                <Label text="Total Sesi" styleClass="quick-stat-label"/>
            </VBox>

            <Region prefWidth="1" styleClass="quick-stat-divider"/>

            <VBox styleClass="quick-stat-item" HBox.hgrow="ALWAYS">
                <Label fx:id="totalFocusMinutesLabel" text="0 mnt" styleClass="quick-stat-value"/>
                <Label text="Total Fokus" styleClass="quick-stat-label"/>
            </VBox>

            <Region prefWidth="1" styleClass="quick-stat-divider"/>

            <VBox styleClass="quick-stat-item" HBox.hgrow="ALWAYS">
                <Label fx:id="tasksCompletedLabel" text="0" styleClass="quick-stat-value"/>
                <Label text="Tugas Selesai" styleClass="quick-stat-label"/>
            </VBox>

            <Region prefWidth="1" styleClass="quick-stat-divider"/>

            <VBox styleClass="quick-stat-item" HBox.hgrow="ALWAYS">
                <Label fx:id="currentStreakLabel" text="0" styleClass="quick-stat-value"/>
                <Label text="Streak" styleClass="quick-stat-label"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- ========== SCROLLABLE SETTINGS ========== -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER"
                styleClass="profile-scroll">
        <VBox styleClass="profile-scroll-content" spacing="20">
            <VBox.margin><Insets top="24" right="28" bottom="28" left="28"/></VBox.margin>

            <!-- ========== PERSONAL INFO CARD ========== -->
            <VBox styleClass="profile-card">
                <Label text="INFORMASI PRIBADI" styleClass="profile-card-title"/>

                <VBox spacing="6" styleClass="profile-field">
                    <Label text="Username" styleClass="profile-field-label"/>
                    <TextField fx:id="editUsernameField"
                               promptText="Masukkan username baru"
                               styleClass="profile-input"
                               visible="false"/>
                    <Label fx:id="usernameDisplayLabel"
                           text="username"
                           styleClass="profile-field-value"/>
                </VBox>

                <VBox spacing="6" styleClass="profile-field">
                    <Label text="Email" styleClass="profile-field-label"/>
                    <TextField fx:id="editEmailField"
                               promptText="Masukkan email baru"
                               styleClass="profile-input"
                               visible="false"/>
                    <Label fx:id="emailDisplayLabel"
                           text="user@example.com"
                           styleClass="profile-field-value"/>
                </VBox>

                <HBox spacing="8" fx:id="personalInfoButtonsBox" styleClass="profile-btn-row">
                    <Button fx:id="editPersonalInfoBtn"
                            text="Edit"
                            styleClass="button, button-outline"
                            onAction="#handleEditPersonalInfo"/>
                    <Button fx:id="savePersonalInfoBtn"
                            text="Simpan"
                            styleClass="button, button-primary"
                            onAction="#handleSavePersonalInfo"
                            visible="false"/>
                    <Button fx:id="cancelPersonalInfoBtn"
                            text="Batal"
                            styleClass="button, button-secondary"
                            onAction="#handleCancelPersonalInfo"
                            visible="false"/>
                </HBox>
            </VBox>

            <!-- ========== PASSWORD CARD ========== -->
            <VBox styleClass="profile-card">
                <Label text="KEAMANAN" styleClass="profile-card-title"/>

                <VBox spacing="6" fx:id="passwordSectionBox">
                    <Label text="Ubah Password" styleClass="profile-field-label"/>

                    <VBox spacing="8" fx:id="passwordInputsBox" visible="false">
                        <Label text="Password Lama" styleClass="profile-field-label-sub"/>
                        <PasswordField fx:id="oldPasswordField"
                                       promptText="Masukkan password lama"
                                       styleClass="profile-input"/>

                        <Label text="Password Baru" styleClass="profile-field-label-sub"/>
                        <PasswordField fx:id="newPasswordField"
                                       promptText="Minimal 6 karakter"
                                       styleClass="profile-input"/>

                        <Label text="Konfirmasi Password Baru" styleClass="profile-field-label-sub"/>
                        <PasswordField fx:id="confirmPasswordField"
                                       promptText="Ulangi password baru"
                                       styleClass="profile-input"/>

                        <Label fx:id="passwordErrorLabel"
                               text=""
                               styleClass="profile-error"
                               visible="false"/>
                    </VBox>

                    <HBox spacing="8" fx:id="passwordButtonsBox" styleClass="profile-btn-row">
                        <Button fx:id="changePasswordBtn"
                                text="Ubah Password"
                                styleClass="button, button-outline"
                                onAction="#handleChangePasswordClick"/>
                        <Button fx:id="savePasswordBtn"
                                text="Simpan"
                                styleClass="button, button-primary"
                                onAction="#handleSavePassword"
                                visible="false"/>
                        <Button fx:id="cancelPasswordBtn"
                                text="Batal"
                                styleClass="button, button-secondary"
                                onAction="#handleCancelPassword"
                                visible="false"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- ========== PREFERENSI CARD ========== -->
            <VBox styleClass="profile-card">
                <Label text="PREFERENSI" styleClass="profile-card-title"/>

                <VBox spacing="6" styleClass="profile-field">
                    <Label text="Notifikasi Default Audio" styleClass="profile-field-label"/>
                    <Label text="Ambient noise akan otomatis diputar saat sesi fokus dimulai (dapat diubah kapan saja)."
                           styleClass="profile-field-desc" wrapText="true"/>
                </VBox>

                <Button text="Informasi Lebih Lanjut"
                        styleClass="link-button"/>
            </VBox>

            <!-- ========== DANGER ZONE CARD ========== -->
            <VBox styleClass="profile-danger-zone">
                <Label text="ZONA BAHAYA" styleClass="profile-card-title-danger"/>

                <Label text="Menghapus akun akan menghilangkan semua data Anda secara permanen. Tindakan ini tidak dapat dibatalkan."
                       styleClass="profile-field-desc" wrapText="true"/>

                <Button fx:id="deleteAccountBtn"
                        text="Hapus Akun Saya"
                        styleClass="button, button-danger"
                        onAction="#handleDeleteAccount"
                        maxWidth="Infinity"/>
            </VBox>

        </VBox>
    </ScrollPane>

</VBox>
